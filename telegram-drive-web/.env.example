# Rahasia — wajib di production (install-vps.sh bisa generate otomatis)
SECRET_KEY=

# Password opsional untuk mengunci halaman web (lapisan ekstra sebelum login akun)
WEB_ACCESS_PASSWORD=

# Daftar akun baru lewat UI (true/false)
ALLOW_REGISTRATION=true

# Admin pertama otomatis jika database user masih kosong (opsional)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Telegram API — opsional di .env (atau atur lewat Pengaturan → Admin di webapp)
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# Batas upload per file (MB)
MAX_UPLOAD_MB=2000

# Batas total ukuran bulk ZIP — unduh/kompres banyak file (MB)
MAX_BULK_ZIP_MB=2000

# LK21 Movie — scrape mandiri
# Default mirror WordPress:
LK21_BASE_URL=https://bridgestoabrighterfuture.org
# Alternatif klasik (tvN.lk21official.*) — set manual di admin atau:
# LK21_BASE_URL=https://tv10.lk21official.cc
LK21_AUTO_DISCOVER=true
LK21_DOMAIN_CACHE_HOURS=6

# Pencarian kode video (opsional) — semua di .env saja, tidak masuk git
# CODE_CATALOG_SCRAPE_BASE_URL=https://your-source.example
# CODE_CATALOG_POSTER_BASE_URL=https://your-poster-cdn.example
# CODE_CATALOG_SEARCH_API_HOST=client-rapi-....recombee.com
# CODE_CATALOG_SEARCH_API_DATABASE=your-db-id
# CODE_CATALOG_SEARCH_API_TOKEN=your-public-token
# CODE_CATALOG_HLS_CDN_SUFFIXES=cdn1.example.com,cdn2.example.com
# CODE_CATALOG_SCRAPE_COOKIES_FILE=./data/code_catalog/cookies.txt

# Port lokal app (nginx VPS proxy ke sini)
APP_PORT=14202
HOST=127.0.0.1

# Folder data (session Telegram) — relatif ke folder app
DATA_DIR=./data

# YouTube / yt-dlp — wajib cookies agar tidak kena "Sign in to confirm you're not a bot"
# Export dari browser yang sudah login YouTube (Netscape format), simpan sebagai:
#   data/ytdlp/cookies.txt
# Atau path kustom:
# YT_DLP_COOKIES_FILE=./data/ytdlp/cookies.txt
# Opsional: ambil cookies langsung dari browser di server (jika ada GUI/browser):
# YT_DLP_COOKIES_FROM_BROWSER=chrome
# YT_DLP_COOKIES_FROM_BROWSER=firefox:default